{
  "imports": {
    "@supabase/supabase-js": "npm:@supabase/supabase-js@2",
    "postgres": "https://deno.land/x/postgres@v0.19.3/mod.ts",
    "@std/assert": "jsr:@std/assert@1",
    "@std/dotenv": "jsr:@std/dotenv/load",
    "@std/crypto": "jsr:@std/crypto"
  },
  "fmt": {
    "singleQuote": true,
    "semiColons": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "useTabs": false
